# Runtime environment variables

# App
APP_MODE=mock
APP_SERVERS=all
# 留空则使用 config.yml 中对应模式的 debug；仅在本机需要覆盖时设置
# APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# Authentication
APP_API_KEYS=mock-api-key-001,mock-api-key-002

# xtquant / QMT
QMT_USERDATA_PATH=D:\QMT\userdata_mini
APP_ENABLE_PROD_ORDERS=false
